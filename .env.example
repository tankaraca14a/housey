# Booking notification emails (optional — bookings save without it)
# Get a key at https://resend.com
RESEND_API_KEY=

# Vercel KV / Upstash Redis (REQUIRED for production on Vercel).
# Provision via Vercel dashboard → Storage → Create KV database, or sign up
# directly at https://upstash.com and copy the REST URL + token.
# When BOTH are set, the app uses KV. When unset, it falls back to JSON files
# (data/*.json) — fine for local dev, NOT viable on Vercel's read-only fs.
KV_REST_API_URL=
KV_REST_API_TOKEN=
